# Application
APP_ENV=development
PORT=8080

# Database (same as your Laravel .env)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ibnu_hafidz
DB_USERNAME=root
DB_PASSWORD=

# JWT Secrets (change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me

# CORS (Web dev servers: Vue + Expo)
CORS_ORIGINS=http://localhost:5173,http://localhost:8082,http://127.0.0.1:8082

# S3/Wasabi (copy from Laravel .env)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
